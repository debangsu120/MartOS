# Auto-detect text files
* text=auto

# Source code - always LF
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.css text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Config files
*.env text eol=lf
*.env.example text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# Binary files - treat as binary
*.pdf binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text eol=lf
